{
    "name": "phpquality/docker-app",
    "description": "Minimal Symfony skeleton for PhpQuality Docker image",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "phpquality/phpquality-bundle": "^2.0",
        "symfony/console": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
