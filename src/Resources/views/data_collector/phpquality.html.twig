{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block toolbar %}
    {% set icon %}
        <span class="icon">
            {{ include('@PhpQuality/data_collector/icon.svg') }}
        </span>
        {% set summary = collector.summary %}
        {% set totalViolations = collector.totalViolations %}
        <span class="sf-toolbar-value">{{ summary.totalFiles }}</span>
        <span class="sf-toolbar-label">files</span>
        {% if totalViolations > 0 %}
            <span class="sf-toolbar-value sf-toolbar-status sf-toolbar-status-red">{{ totalViolations }}</span>
        {% endif %}
    {% endset %}

    {% set text %}
        <div class="sf-toolbar-info-piece">
            <b>Files analyzed</b>
            <span>{{ summary.totalFiles }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Classes</b>
            <span>{{ summary.totalClasses }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Methods</b>
            <span>{{ summary.totalMethods }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Avg MI</b>
            <span class="{{ summary.averageMi < 40 ? 'sf-toolbar-status-red' : (summary.averageMi < 65 ? 'sf-toolbar-status-yellow' : 'sf-toolbar-status-green') }}">
                {{ summary.averageMi }}
            </span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Violations</b>
            <span class="{{ totalViolations > 0 ? 'sf-toolbar-status-red' : 'sf-toolbar-status-green' }}">
                {{ totalViolations }}
            </span>
        </div>
    {% endset %}

    {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: profiler_url }) }}
{% endblock %}

{% block menu %}
    <span class="label {{ collector.totalViolations > 0 ? 'label-status-error' : '' }}">
        <span class="icon">
            {{ include('@PhpQuality/data_collector/icon.svg') }}
        </span>
        <strong>PHP Quality</strong>
        {% if collector.totalViolations > 0 %}
            <span class="count">
                <span>{{ collector.totalViolations }}</span>
            </span>
        {% endif %}
    </span>
{% endblock %}

{% block panel %}
    <h2>PHP Quality Analysis</h2>

    {% set summary = collector.summary %}
    {% set thresholds = collector.thresholds %}

    <div class="metrics">
        <div class="metric">
            <span class="value">{{ summary.totalFiles }}</span>
            <span class="label">Files</span>
        </div>
        <div class="metric">
            <span class="value">{{ summary.totalClasses }}</span>
            <span class="label">Classes</span>
        </div>
        <div class="metric">
            <span class="value">{{ summary.totalMethods }}</span>
            <span class="label">Methods</span>
        </div>
        <div class="metric">
            <span class="value {{ summary.averageMi < thresholds.mi ? 'status-error' : 'status-success' }}">
                {{ summary.averageMi }}
            </span>
            <span class="label">Avg MI (min: {{ thresholds.mi }})</span>
        </div>
        <div class="metric">
            <span class="value {{ summary.averageCcn > thresholds.ccn ? 'status-error' : 'status-success' }}">
                {{ summary.averageCcn }}
            </span>
            <span class="label">Avg CCN (max: {{ thresholds.ccn }})</span>
        </div>
        <div class="metric">
            <span class="value {{ summary.averageLcom > thresholds.lcom ? 'status-error' : 'status-success' }}">
                {{ summary.averageLcom }}
            </span>
            <span class="label">Avg LCOM (max: {{ thresholds.lcom }})</span>
        </div>
    </div>

    <h3>Violations Summary</h3>
    <table>
        <thead>
            <tr>
                <th>Metric</th>
                <th>Threshold</th>
                <th>Violations</th>
            </tr>
        </thead>
        <tbody>
            <tr class="{{ summary.violations.ccn > 0 ? 'status-error' : '' }}">
                <td>Cyclomatic Complexity (CCN)</td>
                <td>max {{ thresholds.ccn }}</td>
                <td>{{ summary.violations.ccn }}</td>
            </tr>
            <tr class="{{ summary.violations.lcom > 0 ? 'status-error' : '' }}">
                <td>Lack of Cohesion (LCOM)</td>
                <td>max {{ thresholds.lcom }}</td>
                <td>{{ summary.violations.lcom }}</td>
            </tr>
            <tr class="{{ summary.violations.mi > 0 ? 'status-error' : '' }}">
                <td>Maintainability Index (MI)</td>
                <td>min {{ thresholds.mi }}</td>
                <td>{{ summary.violations.mi }}</td>
            </tr>
        </tbody>
    </table>

    <h3>Analyzed Files</h3>
    {% if collector.files|length > 0 %}
        <table>
            <thead>
                <tr>
                    <th>File</th>
                    <th>MI</th>
                    <th>Max CCN</th>
                    <th>Avg LCOM</th>
                    <th>Classes</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for file in collector.files %}
                    <tr class="{{ file.hasViolations ? 'status-warning' : '' }}">
                        <td>{{ file.path }}</td>
                        <td>
                            <span class="badge {{ file.mi < thresholds.mi ? 'badge-error' : 'badge-success' }}">
                                {{ file.mi }} ({{ file.miRating }})
                            </span>
                        </td>
                        <td>
                            <span class="badge {{ file.maxCcn > thresholds.ccn ? 'badge-error' : 'badge-success' }}">
                                {{ file.maxCcn }}
                            </span>
                        </td>
                        <td>
                            <span class="badge {{ file.avgLcom > thresholds.lcom ? 'badge-error' : 'badge-success' }}">
                                {{ file.avgLcom }}
                            </span>
                        </td>
                        <td>{{ file.classCount }}</td>
                        <td>
                            {% if file.hasViolations %}
                                <span class="badge badge-error">{{ file.violations|length }} violation(s)</span>
                            {% else %}
                                <span class="badge badge-success">OK</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% if file.hasViolations %}
                        <tr class="violation-details">
                            <td colspan="6">
                                <ul class="violation-list">
                                    {% for violation in file.violations %}
                                        <li>
                                            <strong>{{ violation.type|upper }}</strong>:
                                            {% if violation.method is defined %}
                                                {{ violation.class }}::{{ violation.method }}()
                                            {% else %}
                                                {{ violation.class }}
                                            {% endif %}
                                            = <code>{{ violation.value }}</code>
                                            (threshold: {{ violation.threshold }})
                                        </li>
                                    {% endfor %}
                                </ul>
                            </td>
                        </tr>
                    {% endif %}
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="empty">
            <p>No PHP files from src/ were loaded during this request.</p>
        </div>
    {% endif %}

    <style>
        .metrics {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 30px;
        }
        .metric {
            background: var(--base-1);
            border: 1px solid var(--base-2);
            border-radius: 4px;
            padding: 15px 20px;
            text-align: center;
            min-width: 100px;
        }
        .metric .value {
            display: block;
            font-size: 24px;
            font-weight: bold;
            color: var(--base-6);
        }
        .metric .label {
            display: block;
            font-size: 12px;
            color: var(--base-4);
            margin-top: 5px;
        }
        .status-success { color: var(--color-success) !important; }
        .status-error { color: var(--color-error) !important; }
        .status-warning { background: rgba(255, 200, 0, 0.1); }
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 3px;
            font-size: 12px;
            font-weight: bold;
        }
        .badge-success { background: var(--color-success); color: #fff; }
        .badge-error { background: var(--color-error); color: #fff; }
        .violation-details {
            background: var(--base-1);
        }
        .violation-list {
            margin: 0;
            padding: 10px 20px;
            list-style: none;
        }
        .violation-list li {
            padding: 3px 0;
            font-size: 13px;
        }
        .violation-list code {
            background: var(--base-2);
            padding: 1px 4px;
            border-radius: 2px;
        }
    </style>
{% endblock %}
