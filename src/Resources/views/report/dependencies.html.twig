{% extends '@PhpQuality/report/base.html.twig' %}

{% block title %}{{ 'dependencies.title'|trans }} - PhpQuality{% endblock %}

{% block nav_dependencies %}active{% endblock %}

{% block content %}
    <div class="page-header">
        <h1>{{ 'dependencies.title'|trans }}</h1>
        <p>{{ 'dependencies.description'|trans }}</p>
    </div>

    {% if dependencies.found %}
    <!-- Summary Cards -->
    <section class="section">
        <div class="grid grid-4">
            <div class="card metric-card">
                <div class="metric-label">{{ 'dependencies.require'|trans }}</div>
                <div class="metric-value">{{ dependencies.require|length }}</div>
                <div class="text-muted">{{ 'dependencies.production'|trans }}</div>
            </div>
            <div class="card metric-card">
                <div class="metric-label">{{ 'dependencies.require_dev'|trans }}</div>
                <div class="metric-value">{{ dependencies.requireDev|length }}</div>
                <div class="text-muted">{{ 'dependencies.development'|trans }}</div>
            </div>
            <div class="card metric-card">
                <div class="metric-label">{{ 'dependencies.total_installed'|trans }}</div>
                <div class="metric-value">{{ dependencies.installed|length }}</div>
                <div class="text-muted">{{ 'dependencies.from_lock'|trans }}</div>
            </div>
            <div class="card metric-card {{ dependencies.outdated|length > 0 ? 'rating-D' : 'rating-A' }}">
                <div class="metric-label">{{ 'dependencies.outdated'|trans }}</div>
                <div class="metric-value">{{ dependencies.outdated|length }}</div>
                <div class="text-muted">{{ 'dependencies.needs_update'|trans }}</div>
            </div>
        </div>
    </section>

    <!-- Support Status / Roadmap -->
    {% if dependencies.supportStatus|length > 0 %}
    <section class="section">
        <h2>{{ 'dependencies.support_status'|trans }}</h2>
        <div class="grid grid-{{ dependencies.supportStatus|length > 2 ? '4' : dependencies.supportStatus|length }}">
            {% for key, item in dependencies.supportStatus %}
            <div class="card support-card {{ item.supported ? 'support-active' : 'support-eol' }}">
                <div class="support-header">
                    <span class="support-name">{{ item.name }}</span>
                    <span class="support-version">{{ item.version }}</span>
                </div>
                <div class="support-badges">
                    {% if item.lts %}
                    <span class="label label-info">LTS</span>
                    {% endif %}
                    {% if item.supported %}
                    <span class="label label-success">{{ 'dependencies.supported'|trans }}</span>
                    {% else %}
                    <span class="label label-danger">EOL</span>
                    {% endif %}
                </div>
                <div class="support-eol">
                    {% if item.supported %}
                        <span class="text-muted">{{ 'dependencies.eol_in'|trans }}:</span>
                        <strong>{{ item.days_until_eol }} {{ 'dependencies.days'|trans }}</strong>
                        <div class="text-muted" style="font-size: 0.8rem;">{{ item.eol_date }}</div>
                    {% else %}
                        <span class="text-danger">{{ 'dependencies.eol_since'|trans }}:</span>
                        <strong class="text-danger">{{ item.days_until_eol|abs }} {{ 'dependencies.days'|trans }}</strong>
                        <div class="text-muted" style="font-size: 0.8rem;">{{ item.eol_date }}</div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    <!-- Dependency Graph -->
    <section class="section">
        <h2>{{ 'dependencies.graph'|trans }}</h2>
        <div class="card">
            <div class="dep-graph" id="dependencyGraph">
                <div class="dep-center">
                    <div class="dep-project">{{ dependencies.name }}</div>
                </div>
                <div class="dep-ring dep-ring-require">
                    {% for package, version in dependencies.require %}
                        {% if not package starts with 'php' and not package starts with 'ext-' %}
                        <div class="dep-node" title="{{ package }}: {{ version }}">
                            {{ package|split('/')|last }}
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <!-- Production Dependencies -->
    <section class="section">
        <h2>{{ 'dependencies.production_deps'|trans }}</h2>
        <div class="card">
            <table>
                <thead>
                    <tr>
                        <th>{{ 'tables.package'|trans }}</th>
                        <th>{{ 'dependencies.required_version'|trans }}</th>
                        <th>{{ 'dependencies.installed_version'|trans }}</th>
                        <th>{{ 'dependencies.license'|trans }}</th>
                        <th>{{ 'dependencies.status'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for package, version in dependencies.require %}
                        {% if not package starts with 'php' and not package starts with 'ext-' %}
                        {% set installed = dependencies.installedMap[package]|default(null) %}
                        <tr>
                            <td>
                                <a href="https://packagist.org/packages/{{ package }}" target="_blank" rel="noopener">
                                    {{ package }}
                                </a>
                            </td>
                            <td class="text-muted">{{ version }}</td>
                            <td>{{ installed.version ?? '-' }}</td>
                            <td class="text-muted">{{ installed.license|default(['?'])|join(', ') }}</td>
                            <td>
                                {% if installed %}
                                    <span class="badge badge-success">{{ 'dependencies.installed'|trans }}</span>
                                {% else %}
                                    <span class="badge badge-warning">{{ 'dependencies.not_installed'|trans }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <!-- Development Dependencies -->
    {% if dependencies.requireDev|length > 0 %}
    <section class="section">
        <h2>{{ 'dependencies.dev_deps'|trans }}</h2>
        <div class="card">
            <table>
                <thead>
                    <tr>
                        <th>{{ 'tables.package'|trans }}</th>
                        <th>{{ 'dependencies.required_version'|trans }}</th>
                        <th>{{ 'dependencies.installed_version'|trans }}</th>
                        <th>{{ 'dependencies.license'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for package, version in dependencies.requireDev %}
                        {% set installed = dependencies.installedMap[package]|default(null) %}
                        <tr>
                            <td>
                                <a href="https://packagist.org/packages/{{ package }}" target="_blank" rel="noopener">
                                    {{ package }}
                                </a>
                            </td>
                            <td class="text-muted">{{ version }}</td>
                            <td>{{ installed.version ?? '-' }}</td>
                            <td class="text-muted">{{ installed.license|default(['?'])|join(', ') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
    {% endif %}

    <!-- Outdated Packages -->
    {% if dependencies.outdated|length > 0 %}
    <section class="section">
        <h2>{{ 'dependencies.outdated_packages'|trans }}</h2>
        <div class="card">
            <div class="warning-box" style="margin-bottom: 1rem;">
                <strong>{{ 'common.warning'|trans }}:</strong> {{ 'dependencies.outdated_warning'|trans }}
            </div>
            <table>
                <thead>
                    <tr>
                        <th>{{ 'tables.package'|trans }}</th>
                        <th>{{ 'dependencies.installed_version'|trans }}</th>
                        <th>{{ 'dependencies.latest_version'|trans }}</th>
                        <th>{{ 'dependencies.constraint'|trans }}</th>
                        <th>{{ 'dependencies.severity'|trans }}</th>
                        <th>{{ 'dependencies.support_status'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for pkg in dependencies.outdated %}
                    <tr>
                        <td>
                            <a href="https://packagist.org/packages/{{ pkg.name }}" target="_blank" rel="noopener">
                                {{ pkg.name }}
                            </a>
                        </td>
                        <td class="text-muted">{{ pkg.installed }}</td>
                        <td class="text-success">{{ pkg.latest }}</td>
                        <td><code>{{ pkg.constraint }}</code></td>
                        <td>
                            {% if pkg.severity == 3 %}
                                <span class="label label-danger">{{ 'dependencies.major'|trans }}</span>
                            {% elseif pkg.severity == 2 %}
                                <span class="label label-warning">{{ 'dependencies.minor'|trans }}</span>
                            {% else %}
                                <span class="label label-success">{{ 'dependencies.patch'|trans }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if pkg.support %}
                                <div class="support-inline">
                                    <span class="text-muted">{{ pkg.support.framework }} {{ pkg.support.version }}</span>
                                    {% if pkg.support.lts %}<span class="label label-info" style="font-size: 0.65rem; padding: 0.1rem 0.4rem;">LTS</span>{% endif %}
                                    {% if pkg.support.supported %}
                                        <span class="label label-success" style="font-size: 0.65rem; padding: 0.1rem 0.4rem;">OK</span>
                                    {% else %}
                                        <span class="label label-danger" style="font-size: 0.65rem; padding: 0.1rem 0.4rem;">EOL</span>
                                    {% endif %}
                                </div>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
    {% endif %}

    <!-- PHP Requirements -->
    <section class="section">
        <h2>{{ 'dependencies.php_requirements'|trans }}</h2>
        <div class="card">
            <div class="grid grid-3">
                <div>
                    <h4>PHP Version</h4>
                    <p class="metric-value" style="font-size: 1.5rem;">{{ dependencies.require.php|default('Not specified') }}</p>
                </div>
                <div>
                    <h4>{{ 'dependencies.extensions'|trans }}</h4>
                    <ul class="extension-list">
                        {% for package, version in dependencies.require %}
                            {% if package starts with 'ext-' %}
                            <li>
                                <span class="badge badge-info">{{ package|replace({'ext-': ''}) }}</span>
                            </li>
                            {% endif %}
                        {% else %}
                            <li class="text-muted">{{ 'common.none'|trans }}</li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <h4>{{ 'dependencies.autoload'|trans }}</h4>
                    {% if dependencies.autoload %}
                    <ul class="namespace-list">
                        {% for namespace, path in dependencies.autoload['psr-4']|default({}) %}
                        <li>
                            <code>{{ namespace }}</code>
                            <span class="text-muted">→ {{ path }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                    {% else %}
                        <p class="text-muted">{{ 'dependencies.no_autoload'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    <!-- License Summary -->
    <section class="section">
        <h2>{{ 'dependencies.license_summary'|trans }}</h2>
        <div class="card">
            <div class="grid grid-4">
                {% for license, count in dependencies.licensesSummary %}
                <div class="license-card">
                    <div class="metric-value">{{ count }}</div>
                    <div class="metric-label">{{ license }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {% else %}
    <!-- No composer.json found -->
    <section class="section">
        <div class="card">
            <div class="empty-state">
                <div class="empty-icon">📦</div>
                <h3>{{ 'dependencies.not_found'|trans }}</h3>
                <p class="text-muted">{{ 'dependencies.not_found_desc'|trans }}</p>
            </div>
        </div>
    </section>
    {% endif %}
{% endblock %}

{% block styles %}
<style>
    .dep-graph {
        position: relative;
        height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .dep-center {
        position: absolute;
        z-index: 2;
    }
    .dep-project {
        background: var(--accent, #3b82f6);
        color: white;
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: bold;
        box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3);
    }
    .dep-ring {
        position: absolute;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        max-width: 90%;
    }
    .dep-node {
        background: var(--bg-subtle, #f3f4f6);
        border: 1px solid var(--border, #e5e7eb);
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        cursor: default;
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .dep-node:hover {
        transform: scale(1.05);
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .extension-list, .namespace-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .extension-list li, .namespace-list li {
        padding: 0.25rem 0;
    }
    .namespace-list code {
        background: var(--bg-subtle, #f3f4f6);
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        font-size: 0.85rem;
    }
    .license-card {
        text-align: center;
        padding: 1rem;
    }
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }
    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .support-card {
        text-align: center;
        transition: transform 0.2s;
    }
    .support-card:hover {
        transform: translateY(-2px);
    }
    .support-active {
        border-left: 4px solid var(--color-success);
    }
    .support-eol {
        border-left: 4px solid var(--color-danger);
        background: rgba(239, 68, 68, 0.05);
    }
    .support-header {
        margin-bottom: 0.75rem;
    }
    .support-name {
        font-weight: 700;
        font-size: 1.1rem;
    }
    .support-version {
        margin-left: 0.5rem;
        color: var(--color-text-muted);
        font-size: 1.1rem;
    }
    .support-badges {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        margin-bottom: 0.75rem;
    }
    .support-eol {
        font-size: 0.9rem;
    }

    @media print {
        .dep-graph { display: none; }
    }
</style>
{% endblock %}
