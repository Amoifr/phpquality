{
    "name": "phpquality/phpquality",
    "description": "Static analyzer for PHP code metrics and quality",
    "type": "project",
    "license": "MIT",
    "keywords": ["php", "metrics", "static-analysis", "code-quality", "complexity"],
    "require": {
        "php": ">=8.3",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^7.0",
        "symfony/filesystem": "^7.0",
        "symfony/finder": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/translation": "^7.4",
        "symfony/twig-bundle": "^7.0",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/var-dumper": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
