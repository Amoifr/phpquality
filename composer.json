{
    "name": "phpquality/phpquality-bundle",
    "description": "Symfony bundle for PHP static code analysis, metrics, and quality reports",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "php",
        "metrics",
        "static-analysis",
        "code-quality",
        "complexity",
        "symfony-bundle",
        "phpmetrics"
    ],
    "authors": [
        {
            "name": "Pascal CESCON",
            "email": "pascal.cescon@gmail.com"
        }
    ],
    "homepage": "https://github.com/amoifr/PhpQuality",
    "require": {
        "php": ">=8.3",
        "nikic/php-parser": "^5.0",
        "symfony/config": "^7.0",
        "symfony/console": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/filesystem": "^7.0",
        "symfony/finder": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/translation": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/var-dumper": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "PhpQuality\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpQuality\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
